    {
      "parameters": {
        "jsCode": "function propVal(row, name) {\n  const p = row?.properties?.[name];\n  if (p) {\n    switch (p.type) {\n      case 'title': return (p.title || []).map((t) => t.plain_text).join('');\n      case 'rich_text': return (p.rich_text || []).map((t) => t.plain_text).join('');\n      case 'select': return p.select?.name || '';\n      case 'multi_select': return (p.multi_select || []).map((o) => o.name);\n      case 'date': return p.date?.start || '';\n      default: return '';\n    }\n  }\n  for (const k of [name, 'property_' + name]) {\n    if (row?.[k] !== undefined && row?.[k] !== null) return row[k];\n  }\n  return '';\n}\nfunction toList(value) {\n  if (Array.isArray(value)) return value.map((x) => String(x?.name || x).trim()).filter(Boolean);\n  const t = String(value ?? '').trim();\n  if (!t) return [];\n  try { const p = JSON.parse(t); if (Array.isArray(p)) return p.map((x) => String(x?.name || x).trim()).filter(Boolean); } catch (e) {}\n  return t.split(/[,，、]/).map((s) => s.trim()).filter(Boolean);\n}\n\nconst operators = $input.all().map((item) => {\n  const row = item.json || {};\n  return {\n    pageId: row.id || row.pageId || '',\n    name: propVal(row, '名稱'),\n    nickname: propVal(row, '暱稱'),\n    userId: propVal(row, 'LINE userId'),\n    displayName: propVal(row, 'LINE顯示名稱'),\n    status: propVal(row, '狀態') || '待審核',\n    role: propVal(row, '角色'),\n    features: toList(propVal(row, '可使用功能')),\n    note: propVal(row, '備註'),\n    firstSeen: propVal(row, '首次進入時間'),\n    approvedAt: propVal(row, '開通時間'),\n    approvedBy: propVal(row, '開通人員'),\n    lastUsed: propVal(row, '最後使用時間')\n  };\n}).filter((op) => op.pageId || op.userId || op.name);\n\nconst order = { '待審核': 0, '已開通': 1, '停用': 2 };\noperators.sort((a, b) => {\n  const d = (order[a.status] ?? 9) - (order[b.status] ?? 9);\n  if (d) return d;\n  return String(a.name || '').localeCompare(String(b.name || ''), 'zh-Hant');\n});\n\nconst response = { ok: true, operators };\nreturn [{ json: { ...response, response } }];"
      },
