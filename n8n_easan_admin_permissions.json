      "parameters": {
        "jsCode": "const item = $input.first().json || {};\nconst body = item.body || item;\nconst expectedPassword = 'gundam';\nconst password = String(body.password || '').trim();\nconst action = String(body.action || 'list').trim();\nconst pageId = String(body.pageId || '').trim();\nconst status = ['待審核', '已開通', '停用'].includes(body.status) ? body.status : '待審核';\n\nlet features = [];\nif (Array.isArray(body.features)) features = body.features.map((f) => String(f).trim()).filter(Boolean);\nelse if (body.ocrEnabled === true || body.ocrEnabled === 'true') features = ['OCR補料單'];\nconst validFeatures = ['OCR補料單', '報表查看', '權限管理'];\nfeatures = features.filter((f) => validFeatures.includes(f));\n\nconst role = ['操作員', '管理員'].includes(body.role) ? body.role : '';\nconst approver = String(body.approver || '').trim();\nconst nickname = String(body.nickname || '').trim();\nconst nowIso = new Date().toISOString();\nconst approvedAtIso = status === '已開通' ? nowIso : '';\nconst approverName = status === '已開通' ? (approver || '管理員') : '';\n\nreturn [{\n  json: {\n    ok: Boolean(password && password === expectedPassword),\n    action,\n    pageId,\n    status,\n    features,\n    role,\n    approver: approverName,\n    nickname,\n    approvedAtIso,\n    nowIso,\n    response: { ok: false, message: '管理密碼錯誤或沒有權限' }\n  }\n}];"
