    {
      "parameters": {
        "jsCode": "const payload = $('整理與驗證列').first().json;\nconst classified = $('分類動作').all().map((i) => i.json || {});\nconst mode = payload.mode;\n\nfunction safeAll(name) {\n  try { return $(name).all().map((i) => i.json || {}); } catch (e) { return []; }\n}\n\nconst invalidRows = classified.filter((c) => c.action === 'invalid');\nconst createRows = classified.filter((c) => c.action === 'create');\nconst updateRows = classified.filter((c) => c.action === 'update');\n\nlet created = 0;\nlet updated = 0;\nlet failed = 0;\nconst skipped = invalidRows.length;\n\nconst rows = [];\nfor (const c of invalidRows) {\n  rows.push({ partNo: c.partNo, category: '', action: '-', status: '略過', message: c.message || '' });\n}\n\nif (mode !== 'import') {\n  for (const c of createRows) rows.push({ partNo: c.partNo, category: c['分類'], action: '將新增', status: '預覽', message: '' });\n  for (const c of updateRows) rows.push({ partNo: c.partNo, category: c['分類'], action: '將更新', status: '預覽', message: '' });\n  return [{ json: { ok: true, mode: 'preview', summary: { total: payload.total, valid: payload.valid, created: 0, updated: 0, skipped, failed: 0 }, rows } }];\n}\n\nconst createdItems = safeAll('新增主檔');\nconst updatedItems = safeAll('更新主檔');\nfor (const it of createdItems) {\n  if (it.error) failed += 1; else created += 1;\n}\nfor (const it of updatedItems) {\n  if (it.error) failed += 1; else updated += 1;\n}\nfor (const c of createRows) rows.push({ partNo: c.partNo, category: c['分類'], action: '新增', status: 'OK', message: '' });\nfor (const c of updateRows) rows.push({ partNo: c.partNo, category: c['分類'], action: '更新', status: 'OK', message: '' });\n\nreturn [{ json: { ok: true, mode: 'import', summary: { total: payload.total, valid: payload.valid, created, updated, skipped, failed }, rows } }];"
      },
