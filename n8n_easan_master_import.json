        "jsCode": "const item = $input.first();\nconst body = item.json?.body || item.json || {};\nconst expectedPassword = 'gundam';\nconst password = String(body.password || '').trim();\nconst mode = String(body.mode || 'preview').trim() || 'preview';\nconst category = String(body.category || '未分類').trim() || '未分類';\nconst file = item.binary?.file || {};\nconst fileName = String(file.fileName || '').toLowerCase();\nconst mimeType = String(file.mimeType || '').toLowerCase();\nconst isCsv = fileName.endsWith('.csv') || mimeType.includes('csv') || mimeType.includes('text/plain');\n\nreturn [{\n  json: {\n    ok: password === expectedPassword,\n    password,\n    mode,\n    category,\n    fileName,\n    isCsv,\n    response: { ok: false, message: '管理密碼錯誤或沒有權限' }\n  },\n  binary: item.binary\n}];"
