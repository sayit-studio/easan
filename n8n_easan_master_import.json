    {
      "parameters": {
        "jsCode": "const meta = $('驗證密碼與參數').first().json;\nconst rows = $input.all().map((i) => i.json || {});\n\nfunction clean(value) {\n  return String(value ?? '').trim();\n}\nfunction pick(row, keys) {\n  for (const k of keys) {\n    if (row[k] !== undefined && row[k] !== null && String(row[k]).trim() !== '') return row[k];\n  }\n  return '';\n}\n\nconst seen = new Set();\nconst valid = [];\nconst invalid = [];\nfor (const row of rows) {\n  const partNo = clean(pick(row, ['品號', '品号', 'part_no', 'partNo', 'PartNo']));\n  if (!partNo) { invalid.push({ partNo: '', message: '缺少品號' }); continue; }\n  if (seen.has(partNo)) { invalid.push({ partNo, message: '檔案內重複品號' }); continue; }\n  seen.add(partNo);\n  valid.push({\n    partNo,\n    '品名': clean(pick(row, ['品名', 'name'])),\n    '規格': clean(pick(row, ['規格', 'spec'])),\n    '類別名稱': clean(pick(row, ['類別名稱', '類別', 'category_name'])),\n    '單位': clean(pick(row, ['單位', 'unit'])),\n    '分類': clean(pick(row, ['分類', 'category'])) || meta.category || '未分類'\n  });\n}\n\nreturn [{\n  json: {\n    mode: meta.mode,\n    category: meta.category,\n    rows: valid,\n    invalid,\n    total: rows.length,\n    valid: valid.length\n  }\n}];"
      },
