      "parameters": {
        "jsCode": "const item = $input.first().json || {};\nconst body = item.body || item;\nconst password = String(body.password || '').trim();\nconst action = String(body.action || 'query').trim();\nconst category = String(body.category || '').trim();\nconst pageId = String(body.pageId || '').trim();\nconst newCategory = ['OMBRA', '吹氣盒', '未分類'].includes(body.newCategory) ? body.newCategory : '';\nconst newStatus = ['啟用', '停用'].includes(body.newStatus) ? body.newStatus : '';\n\nreturn [{\n  json: {\n    ok: Boolean(password && password === 'gundam'),\n    action,\n    category,\n    pageId,\n    newCategory,\n    newStatus,\n    nowIso: new Date().toISOString(),\n    response: { ok: false, message: '管理密碼錯誤或沒有權限' }\n  }\n}];"
      },
