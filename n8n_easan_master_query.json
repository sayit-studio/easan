    {
      "parameters": {
        "jsCode": "const auth = $('驗證品項請求').first().json || {};\nconst filterCategory = auth.category || '';\nconst rows = $input.all().map((i) => i.json || {});\n\nfunction propVal(row, name) {\n  const p = row?.properties?.[name];\n  if (p) {\n    switch (p.type) {\n      case 'title': return (p.title || []).map((t) => t.plain_text).join('');\n      case 'rich_text': return (p.rich_text || []).map((t) => t.plain_text).join('');\n      case 'select': return p.select?.name || '';\n      case 'date': return p.date?.start || '';\n      default: return '';\n    }\n  }\n  for (const k of [name, 'property_' + name]) {\n    if (row?.[k] !== undefined && row?.[k] !== null) return row[k];\n  }\n  return '';\n}\n\nconst all = rows.map((row) => ({\n  pageId: row.id || '',\n  partNo: propVal(row, '品號'),\n  name: propVal(row, '品名'),\n  spec: propVal(row, '規格'),\n  category: propVal(row, '分類') || '未分類',\n  status: propVal(row, '狀態') || '',\n  unit: propVal(row, '單位'),\n  categoryName: propVal(row, '類別名稱')\n})).filter((x) => x.partNo);\n\nconst counts = {};\nfor (const it of all) counts[it.category] = (counts[it.category] || 0) + 1;\nconst categoryCounts = { total: all.length, ...counts };\n\nconst filtered = filterCategory ? all.filter((x) => x.category === filterCategory) : all;\nfiltered.sort((a, b) => String(a.partNo).localeCompare(String(b.partNo)));\n\nreturn [{\n  json: {\n    ok: true,\n    categoryCounts,\n    total: all.length,\n    filteredCount: filtered.length,\n    items: filtered.slice(0, 500)\n  }\n}];"
      },
      "id": "mq-0000000000000008",
      "name": "整理品項清單",
